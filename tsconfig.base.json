{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@unclecode/contracts": ["packages/contracts/src/index.ts"],
      "@unclecode/config-core": ["packages/config-core/src/index.ts"],
      "@unclecode/context-broker": ["packages/context-broker/src/index.ts"],
      "@unclecode/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@unclecode/session-store": ["packages/session-store/src/index.ts"],
      "@unclecode/runtime-broker": ["packages/runtime-broker/src/index.ts"],
      "@unclecode/providers": ["packages/providers/src/index.ts"],
      "@unclecode/mcp-host": ["packages/mcp-host/src/index.ts"],
      "@unclecode/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@unclecode/tui": ["packages/tui/src/index.tsx"]
    }
  }
}
