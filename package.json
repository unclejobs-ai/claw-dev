{
  "name": "unclecode-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "unclecode": "./bin/unclecode.cjs"
  },
  "description": "UncleCode repo-local coding shell with package boundaries and a unified CLI entrypoint.",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "tsc -p tsconfig.check.json --noEmit",
    "rust:check": "cargo check --workspace",
    "rust:test": "cargo test --workspace",
    "rust:build": "cargo build --workspace",
    "build": "node -e \"require('node:fs').rmSync('dist-work', { recursive: true, force: true })\" && tsc -b tsconfig.json && tsc -p tsconfig.work.json",
    "test:context-broker": "node --conditions=source --import tsx --test tests/context-broker/*.test.mjs",
    "test:session-store": "node --conditions=source --import tsx --test tests/session-store/*.test.mjs",
    "test:memory-bus": "node --conditions=source --import tsx --test tests/memory-bus/*.test.mjs",
    "test:snapshot-store": "node --conditions=source --import tsx --test tests/snapshot-store/*.test.mjs",
    "test:plugin-host": "node --conditions=source --import tsx --test tests/plugin-host/*.test.mjs",
    "test:lsp-bridge": "node --conditions=source --import tsx --test tests/lsp-bridge/*.test.mjs",
    "test:server": "node --conditions=source --import tsx --test tests/unclecode-server/*.test.mjs",
    "test:providers": "node --conditions=source --import tsx --test tests/providers/*.test.mjs",
    "test:contracts": "node --conditions=source --import tsx --test tests/contracts/*.test.mjs",
    "test:runtime-broker": "node --conditions=source --import tsx --test tests/runtime-broker/*.test.mjs",
    "test:orchestrator": "node --conditions=source --import tsx --test tests/orchestrator/*.test.mjs tests/orchestrator/mini-loop/*.test.mjs tests/orchestrator/hooks/*.test.mjs tests/orchestrator/aci/*.test.mjs tests/orchestrator/agentless/*.test.mjs tests/orchestrator/team-adapters/*.test.mjs",
    "test:tui": "node --conditions=source --import tsx --test tests/tui/*.test.mjs",
    "test:cli": "node --conditions=source --import tsx --test tests/cli/*.test.mjs",
    "test:commands": "node --conditions=source --import tsx --test tests/commands/*.test.mjs",
    "test:work": "node --conditions=source --import tsx --test tests/work/*.test.mjs",
    "test:performance": "node --conditions=source --import tsx --test tests/performance/*.test.mjs",
    "test:integration": "npm run build --silent && node --test tests/integration/*.test.mjs",
    "test:integration:performance": "npm run build --silent && node --test tests/integration/unclecode-performance.integration.test.mjs",
    "unclecode": "target/debug/unclecode",
    "unclecode:rust": "cargo run --bin unclecode --",
    "unclecode:dev": "npm run build --silent && node apps/unclecode-cli/dist/index.js"
  },
  "engines": {
    "node": ">=22.18.0 <24"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/genai": "^1.48.0",
    "dotenv": "^17.4.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  }
}
